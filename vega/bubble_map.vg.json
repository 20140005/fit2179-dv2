{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 800,
  "height": 500,

  "title": "Student Living Costs Across Australian Cities",

  "layer": [

    {
      "data": {
        "url": "../data/australia_states.geojson"
      },

      "projection": {
        "type": "mercator",
        "center": [134, -26],
        "scale": 700
      },

      "mark": {
        "type": "geoshape",
        "fill": "#eeeeee",
        "stroke": "white"
      }
    },

    {
      "data": {
        "url": "../data/affordability.csv"
      },

      "projection": {
        "type": "mercator",
        "center": [134, -26],
        "scale": 700
      },

      "transform": [
        {
          "lookup": "city",
          "from": {
            "data": {
              "url": "../data/cities.csv"
            },
            "key": "city",
            "fields": ["latitude", "longitude"]
          }
        }
      ],

      "mark": {
        "type": "circle",
        "opacity": 0.8,
        "stroke": "white",
        "strokeWidth": 1
      },

      "encoding": {

        "longitude": {
          "field": "longitude",
          "type": "quantitative"
        },

        "latitude": {
          "field": "latitude",
          "type": "quantitative"
        },

        "size": {
          "field": "total_cost",
          "type": "quantitative",
          "title": "Total Weekly Cost",
          "scale": {
            "range": [200, 3000]
          }
        },

        "color": {
          "field": "affordability_score",
          "type": "quantitative",
          "title": "Affordability",
          "scale": {
            "scheme": "redyellowgreen"
          }
        },

        "tooltip": [
          {
            "field": "city",
            "type": "nominal"
          },
          {
            "field": "total_cost",
            "type": "quantitative",
            "title": "Weekly Cost ($)"
          },
          {
            "field": "hours_needed",
            "type": "quantitative",
            "title": "Work Hours Needed"
          },
          {
            "field": "affordability_score",
            "type": "quantitative",
            "title": "Affordability Score"
          }
        ]
      }
    }
  ]
}