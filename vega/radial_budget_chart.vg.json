{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 1000,
  "height": 500,

  "title": "Where Does a Melbourne Student's Money Go?",

  "config": {
    "view": {
      "stroke": null
    }
  },

  "data": {
    "url": "../data/melbourne_budget.csv"
  },

  "mark": {
    "type": "arc",
    "innerRadius": 120,
    "stroke": "white",
    "strokeWidth": 2,
    "cornerRadius": 8
  },

  "encoding": {

    "theta": {
      "field": "cost",
      "type": "quantitative"
    },

    "color": {
      "field": "category",
      "type": "nominal",
      "title": "Expense Category"
    },

    "tooltip": [
      {
        "field": "category",
        "type": "nominal"
      },
      {
        "field": "cost",
        "type": "quantitative",
        "title": "Weekly Cost ($)"
      }
    ]
  }
}